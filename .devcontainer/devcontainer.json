{
  "name": "ApplicationSets Development",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    {
      "source": "kiro-config",
      "target": "/home/node/.kiro",
      "type": "volume"
    },
    {
      "source": "kiro-cli-data",
      "target": "/home/node/.local/share/kiro-cli",
      "type": "volume"
    }
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.vscode-typescript-next",
        "amazonwebservices.aws-toolkit-vscode",
        "github.vscode-github-actions",
        "ms-vscode.vscode-json",
        "ms-python.python",
        "ms-python.pylint"
      ]
    }
  },
  "postCreateCommand": "sudo chown -R node:node /home/node/.kiro /home/node/.local && chmod +x .devcontainer/setup.sh .devcontainer/scripts/*.sh && .devcontainer/setup.sh",
  "remoteUser": "node"
}
